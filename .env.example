PLEX_TOKEN=""
PLEX_HOST="http://localhost:32400"

# Optional: when "true" (or "1"/"yes"/"on"), change events also trigger a
# parent-dir scoped scan after the per-file metadata refresh. Default off.
# SCOPED_SCAN_AFTER_CHANGE=false

# Optional: when "true" (or "1"/"yes"/"on"), unlink events also trigger a
# parent-dir scoped scan after the API delete (useful for reconciling empty
# Albums/Shows/Seasons). Default off.
# SCOPED_SCAN_AFTER_UNLINK=false

# Optional file logging. When LOG_FILE is set, every line written to
# console.log / console.error is also appended to this path (relative paths
# resolve against the script directory). LOG_ENABLED can force-disable it
# without unsetting the path (accepts true/false/1/0/yes/no/on/off). The log
# is rolled to <path>.1 once it would exceed LOG_MAX_BYTES (default 10485760
# = 10 MB); the previous .1 is overwritten. CLI flags --log-file PATH and
# --no-log override these on the trigger and orchestrator scripts.
# LOG_FILE=plex-sync.log
# LOG_ENABLED=true
# LOG_MAX_BYTES=10485760
