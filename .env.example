PLEX_TOKEN=""
PLEX_HOST="http://localhost:32400"

# Optional: when "true" (or "1"/"yes"/"on"), change events also trigger a
# parent-dir scoped scan after the per-file metadata refresh. Default off.
# SCOPED_SCAN_AFTER_CHANGE=false

# Optional: when "true" (or "1"/"yes"/"on"), unlink events also trigger a
# parent-dir scoped scan after the API delete (useful for reconciling empty
# Albums/Shows/Seasons). Default off.
# SCOPED_SCAN_AFTER_UNLINK=false
